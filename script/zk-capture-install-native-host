#!/usr/bin/env python3
"""Install the Chrome Native Messaging manifest for zk-capture."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

HOST_NAME = "top.homeward_sky.zk_capture"

BROWSER_DIRS = {
    "chrome": Path("~/Library/Application Support/Google/Chrome/NativeMessagingHosts"),
    "chromium": Path("~/Library/Application Support/Chromium/NativeMessagingHosts"),
    "edge": Path("~/Library/Application Support/Microsoft Edge/NativeMessagingHosts"),
    "brave": Path("~/Library/Application Support/BraveSoftware/Brave-Browser/NativeMessagingHosts"),
}


def main() -> int:
    parser = argparse.ArgumentParser(description="Install zk-capture Chrome Native Messaging host manifest.")
    parser.add_argument("extension_id", help="Chrome extension id after loading chrome/zk-capture as unpacked")
    parser.add_argument("--browser", choices=sorted(BROWSER_DIRS), default="chrome")
    args = parser.parse_args()

    host_path = Path(__file__).resolve().with_name("zk-capture-native-host")
    target_dir = BROWSER_DIRS[args.browser].expanduser()
    target_dir.mkdir(parents=True, exist_ok=True)
    manifest_path = target_dir / f"{HOST_NAME}.json"
    manifest = {
        "name": HOST_NAME,
        "description": "Capture web pages and PDFs into the local ZK wiki",
        "path": str(host_path),
        "type": "stdio",
        "allowed_origins": [f"chrome-extension://{args.extension_id}/"],
    }
    manifest_path.write_text(json.dumps(manifest, indent=2) + "\n", encoding="utf-8")
    print(f"installed {manifest_path}")
    print(f"host: {host_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

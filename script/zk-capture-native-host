#!/usr/bin/env python3
"""Chrome Native Messaging host for script/zk-capture."""

from __future__ import annotations

import json
import os
import struct
import subprocess
import sys
from pathlib import Path


def augment_path() -> None:
    home = str(Path.home())
    extras = [
        "/opt/homebrew/bin",
        "/usr/local/bin",
        "/usr/bin",
        "/bin",
        f"{home}/.local/bin",
        f"{home}/.cargo/bin",
    ]
    os.environ["PATH"] = os.pathsep.join([*extras, os.environ.get("PATH", "")])


def read_message() -> dict | None:
    raw_len = sys.stdin.buffer.read(4)
    if len(raw_len) == 0:
        return None
    if len(raw_len) != 4:
        raise RuntimeError("invalid native message length header")
    length = struct.unpack("<I", raw_len)[0]
    data = sys.stdin.buffer.read(length)
    if len(data) != length:
        raise RuntimeError("truncated native message")
    return json.loads(data.decode("utf-8"))


def write_message(payload: dict) -> None:
    data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
    sys.stdout.buffer.write(struct.pack("<I", len(data)))
    sys.stdout.buffer.write(data)
    sys.stdout.buffer.flush()


def run_capture(args: list[str]) -> dict:
    cli = Path(__file__).resolve().with_name("zk-capture")
    proc = subprocess.run(
        [str(cli), "--json", *args],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        timeout=90,
    )
    stdout = (proc.stdout or "").strip()
    try:
        payload = json.loads(stdout) if stdout else {}
    except json.JSONDecodeError:
        payload = {"ok": False, "error": stdout or proc.stderr or "invalid zk-capture output"}
    if proc.returncode != 0 and payload.get("ok") is not False:
        payload = {"ok": False, "error": proc.stderr or stdout or f"zk-capture exited {proc.returncode}"}
    if proc.stderr and not payload.get("stderr"):
        payload["stderr"] = proc.stderr.strip()
    return payload


def handle(message: dict) -> dict:
    action = message.get("action")
    url = message.get("url") or ""
    title = message.get("title") or ""
    selection = message.get("selection") or ""

    if action == "capturePage":
        return run_capture(["web", "--url", url, "--title", title, "--selection", selection])
    if action in {"capturePdfUrl", "capturePdfLink"}:
        return run_capture(["pdf-url", "--url", url, "--title", title])
    if action == "ping":
        return {"ok": True, "status": "pong"}
    return {"ok": False, "error": f"unknown action: {action}"}


def main() -> int:
    augment_path()
    try:
        message = read_message()
        if message is None:
            return 0
        write_message(handle(message))
        return 0
    except Exception as exc:  # noqa: BLE001 - must return JSON to Chrome.
        write_message({"ok": False, "error": str(exc), "type": exc.__class__.__name__})
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
